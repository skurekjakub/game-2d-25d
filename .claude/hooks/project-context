#!/usr/bin/env bash
# SessionStart hook (project-specific): injects AGENTS.md contract + memory index +
# recent commits as additional context. Fires on startup AND after compaction
# (matcher includes "compact" in settings.json) to prevent post-compaction
# identity-doc decay. See project memory rubber_duk_verdict_skipping for the
# parallel failure mode this addresses on the rule-recall side.

set -euo pipefail

PROJECT_DIR="${CLAUDE_PROJECT_DIR:-$(pwd)}"
MEMORY_DIR="${HOME}/.claude/projects/-home-jakub-repositories-game-2d-25d/memory"

agents_md=""
if [ -f "${PROJECT_DIR}/AGENTS.md" ]; then
    agents_md=$(cat "${PROJECT_DIR}/AGENTS.md")
fi

memory_index=""
if [ -f "${MEMORY_DIR}/MEMORY.md" ]; then
    memory_index=$(cat "${MEMORY_DIR}/MEMORY.md")
fi

recent_commits=""
if git -C "${PROJECT_DIR}" rev-parse --git-dir >/dev/null 2>&1; then
    recent_commits=$(git -C "${PROJECT_DIR}" log --oneline -10 2>/dev/null || echo "")
fi

current_branch=""
if git -C "${PROJECT_DIR}" rev-parse --git-dir >/dev/null 2>&1; then
    current_branch=$(git -C "${PROJECT_DIR}" branch --show-current 2>/dev/null || echo "")
fi

# Bash parameter-substitution JSON-escaper (faster than character-loop).
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

context="<project-context-on-session-start-or-compact>
PROJECT: game-2d-25d (Godot 4.6.2 vampire-survivors clone).
BRANCH: ${current_branch}.

==== AGENTS.md ====
${agents_md}

==== Project memory index (MEMORY.md) ====
${memory_index}

Read individual memory files at ${MEMORY_DIR}/<name>.md when their hooks match what you're doing.

==== Recent commits ====
${recent_commits}

REMEMBER: hand-written .tres/.tscn omit UID attributes; @export var x: Node2D doesn't auto-resolve from NodePath (use NodePath + resolve in _ready); Area2D pickups need set_deferred('monitoring', false) before queue_free; spawning physics nodes from inside body_entered chains needs call_deferred. Read the corresponding memory file before re-deriving these from scratch.
</project-context-on-session-start-or-compact>"

context_escaped=$(escape_for_json "$context")

# Emit JSON per the platform's expected shape (mirrors session-start hook logic).
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "additional_context": "%s"\n}\n' "$context_escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context_escaped"
else
    printf '{\n  "additionalContext": "%s"\n}\n' "$context_escaped"
fi

exit 0
