[sub_resource type="RectangleShape2D" id="WallShape_horizontal"]
size = Vector2(1920, 20)

[sub_resource type="RectangleShape2D" id="WallShape_vertical"]
size = Vector2(20, 1080)

[node name="Arena" type="Node2D"]
script = ExtResource("1_arena")
y_sort_enabled = true

[node name="Floor" type="Polygon2D" parent="."]
z_index = -1
polygon = PackedVector2Array(-960, -540, 960, -540, 960, 540, -960, 540)

; Grid overlay on the floor — placeholder spatial reference until art lands.
; z_index = -1 keeps it behind the y-sorted gameplay layer (player, enemies, walls).
[node name="FloorGrid" type="Node2D" parent="."]
z_index = -1
script = ExtResource("3_floor_grid")

[node name="Walls" type="StaticBody2D" parent="."]

[node name="WallTop" type="CollisionShape2D" parent="Walls"]
position = Vector2(0, -540)
shape = SubResource("WallShape_horizontal")

[node name="WallBottom" type="CollisionShape2D" parent="Walls"]
position = Vector2(0, 540)
shape = SubResource("WallShape_horizontal")

[node name="WallLeft" type="CollisionShape2D" parent="Walls"]
position = Vector2(-960, 0)
shape = SubResource("WallShape_vertical")

[node name="WallRight" type="CollisionShape2D" parent="Walls"]
